# Vaultfire CrewAI — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Write Operations (optional) ──────────────────────────────────────────────
# Required only for vaultfire_register_agent and vaultfire_create_bond.
# Use a dedicated wallet — do NOT use your main/cold wallet.
PRIVATE_KEY=your_private_key_here

# ─── Optional RPC Overrides ───────────────────────────────────────────────────
# Override default public RPC endpoints with your own (e.g. Alchemy, Infura).
# VAULTFIRE_BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# VAULTFIRE_AVALANCHE_RPC=https://avalanche-mainnet.infura.io/v3/YOUR_KEY
# VAULTFIRE_ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# VAULTFIRE_POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
